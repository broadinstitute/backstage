# http://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{diff,patch}]
trim_trailing_whitespace = false

[.{prettierrc,yamllint}]
indent_size = 2
indent_style = space

[.gitignore]
trim_trailing_whitespace = false

[*.{hcl,js,json,md,tf,tfvars,yaml,yml}]
indent_size = 2
indent_style = space

[Kptfile]
indent_size = 2
indent_style = space
